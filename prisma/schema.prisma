generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// store is constrained to "COLES" | "IGA" in application code (SQLite has no enum support)
model Product {
  id                     String    @id @default(cuid())
  name                   String
  imageUrl               String?
  store                  String
  colesProductId         String?   @unique
  igaProductId           String?   @unique
  repurchaseIntervalDays Int       @default(14)
  lastPurchasedAt        DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([store])
  @@index([lastPurchasedAt])
}
