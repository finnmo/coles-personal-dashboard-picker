# Database
# SQLite file path — the data/ directory is volume-mounted in Docker
DATABASE_URL="file:/app/data/dashboard.db"

# List Integration
# Options: todoist | google_tasks | apple_reminders | google_keep
# Leave blank to use local-only list (no mobile sync).
LIST_PROVIDER="todoist"

# ── Todoist (recommended — shared lists, works on iOS + Android) ─────────────
# Get your API token: Todoist → Settings → Integrations → Developer → API token
TODOIST_API_TOKEN=""
# Optional: specific project ID to use. Leave blank to add tasks to your Inbox.
# Create a shared "Shopping" project in Todoist and invite household members.
# Find the ID at: todoist.com/app/project/<ID>  (last segment of the URL)
TODOIST_PROJECT_ID=""

# ── Google Tasks (OAuth2 — personal only, cannot share lists) ────────────────
# Run: npx tsx scripts/google-oauth-setup.ts  to get these values.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
# ID of the Google Tasks list — run the setup script to see your lists.
GOOGLE_TASK_LIST_ID="@default"

# ── Apple Reminders (iOS Shortcuts — write-only, no sync back) ───────────────
# Must match the exact name of your Shortcut on the iOS device.
APPLE_SHORTCUTS_NAME="AddToShopping"

# QR Code Sharing — host LAN IP or hostname for the "Save to phone" QR code
# Required when running inside Docker: the container can't detect the host's real LAN IP.
# Find yours with: ipconfig getifaddr en0  (macOS)  or  hostname -I  (Linux)
# Example: SHARE_HOST=192.168.1.42
SHARE_HOST=""

# Product Search — RapidAPI key (free tier: 1000 req/month)
# Get yours at: https://rapidapi.com/data-holdings-group-data-holdings-group-default/api/coles-product-price-api
# Without this key, only IGA results are returned.
RAPIDAPI_KEY=""
