# Database
# SQLite file path — the data/ directory is volume-mounted in Docker
DATABASE_URL="file:/app/data/dashboard.db"

# Authentication
# Generate with: npx tsx scripts/generate-password-hash.ts <your-password>
APP_PASSWORD_HASH=""
# Random 32+ character string for signing session JWTs
SESSION_SECRET=""
SESSION_EXPIRY_HOURS=24

# List Integration
# Options: apple_reminders | google_tasks | google_keep
# google_keep falls back to google_tasks with a startup warning
LIST_PROVIDER="apple_reminders"

# Apple Reminders (required when LIST_PROVIDER=apple_reminders)
# Must match the exact name of your Shortcut on the iOS device
APPLE_SHORTCUTS_NAME="AddToShopping"

# Google Tasks OAuth2 (required when LIST_PROVIDER=google_tasks or google_keep)
# Set up with: npx tsx scripts/google-oauth-setup.ts
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
# The ID of the Google Tasks list to add items to
GOOGLE_TASK_LIST_ID=""

# Coles product search via RapidAPI (https://rapidapi.com/coles-product-price-api)
RAPIDAPI_KEY=""
